{
  "name": "@nmi-agro/fdm-agents",
  "version": "0.4.1",
  "private": false,
  "description": "AI Agent for Fertilizer Planning",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
