{
    "name": "@nmi-agro/fdm-agents",
    "private": false,
    "version": "0.3.1",
    "description": "AI Agent for Fertilizer Planning",
    "license": "MIT",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "check-types": "tsc --noEmit",
        "preinstall": "npx only-allow pnpm",
        "test": "vitest run",
        "test-coverage": "vitest run --coverage",
        "watch": "vitest"
    },
    "dependencies": {
        "@langchain/core": "^1.1.49",
        "@langchain/google-genai": "^2.1.31",
        "@langchain/langgraph": "^1.4.2",
        "@nmi-agro/fdm-calculator": "workspace:^",
        "@nmi-agro/fdm-core": "workspace:^",
        "@nmi-agro/fdm-data": "workspace:^",
        "@posthog/ai": "^8.2.0",
        "langchain": "^1.4.5",
        "posthog-node": "^5.37.1",
        "zod": "^4.4.3"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "devDependencies": {
        "@nmi-agro/fdm-calculator": "workspace:*",
        "@nmi-agro/fdm-core": "workspace:*",
        "@nmi-agro/fdm-data": "workspace:*",
        "@types/node": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "tsdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
