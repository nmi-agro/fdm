        "@nmi-agro/fdm-data": "workspace:^",
        "@posthog/ai": "^7.17.2",
        "langchain": "^1.3.5",
        "posthog-node": "^5.30.8",
        "zod": "^4.3.6"
    },
    "engines": {
        "node": ">=24.0.0"
    },
    "devDependencies": {
        "@nmi-agro/fdm-calculator": "workspace:*",
        "@nmi-agro/fdm-core": "workspace:*",
        "@nmi-agro/fdm-data": "workspace:*",
        "@types/node": "catalog:",
