# -------------------------------------
# General Application Configuration
# -------------------------------------
# Sets the environment (development, production). Affects logging, error handling, etc.
# Required: Yes
NODE_ENV=

# Public name of the application displayed in the UI.
# Required: Yes
PUBLIC_FDM_NAME=

# Base URL of the application (used for API calls, etc.).
# Example: http://localhost:5173 or https://yourdomain.com
# Required: Yes
PUBLIC_FDM_URL=

# URL to the privacy policy Markdown (.md) file.
# The file is fetched server-side and rendered as HTML in the page body.
# Required: Yes
FDM_PRIVACY_URL=

# URL to the datasets used for FDM.
# Example: https://yourdomain.com/storage/datasets
# Required: Yes
PUBLIC_FDM_DATASETS_URL=

# Port the application server will listen on.
# Required: Yes (Defaults may exist in deployment environment)
PORT=

# -------------------------------------
# Session Management
# -------------------------------------
# Secret key used to sign session cookies. MUST be a strong, random string.
# Keep this secret and rotate periodically.
# Required: Yes
FDM_SESSION_SECRET=

# -------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------
# Required: Yes
POSTGRES_HOST=
POSTGRES_PORT=5432 # Default PostgreSQL port
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# -------------------------------------
# Authentication (Better Auth & OAuth Providers)
# -------------------------------------
# Secret key used BY the better-auth library.
# Required: Yes
BETTER_AUTH_SECRET=

# Full base URL of this application (used for redirects by better-auth).
# Example: http://localhost:5173 or https://yourdomain.com
# Required: Yes
BETTER_AUTH_URL=

# Google OAuth Credentials (Optional: Leave empty to disable Google Sign-In)
# Required: No
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth Credentials (Optional: Leave empty to disable Microsoft Sign-In)
# Authentication uses a certificate credential (private_key_jwt) instead of a client secret.
# Upload the public certificate in Entra: App registration → Certificates & secrets → Certificates.
# Store the private key in Google Secret Manager and surface it as an env var.
# Required: No
MS_CLIENT_ID=
# Tenant ID: "common" accepts users from any Microsoft organisation (incl. personal accounts).
# Set to your Entra tenant GUID to restrict to a single organisation.
MS_TENANT_ID=common
# Inline PKCS#8 PEM private key (-----BEGIN PRIVATE KEY-----). Never commit this value.
# Accepts either the inline PEM content OR a file path to the PEM file.
# Generate key pair. From PowerShell (recommended on Windows) or Linux/macOS:
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout ms-signin-private.pem -out ms-signin-public.crt -days 730 -subj "/CN=fdm-microsoft-signin"
# From Git Bash on Windows (MSYS_NO_PATHCONV=1 prevents path expansion):
#   MSYS_NO_PATHCONV=1 openssl req -x509 -newkey rsa:2048 -nodes -keyout ms-signin-private.pem -out ms-signin-public.crt -days 730 -subj "/CN=fdm-microsoft-signin"
# Upload ms-signin-public.crt to Entra, then store the contents of ms-signin-private.pem here.
MS_PRIVATE_KEY=
# Public certificate PEM (-----BEGIN CERTIFICATE-----). Paste the full contents of ms-signin-public.crt,
# OR provide a file path to the .crt file. The thumbprint is derived automatically.
MS_CERTIFICATE=
# Alternative to MS_CERTIFICATE: pre-computed base64url SHA-1 thumbprint.
# Compute locally: openssl x509 -in ms-signin-public.crt -outform DER | openssl dgst -sha1 -binary | base64 | tr '+/' '-_' | tr -d '='
# (The Entra portal truncates the thumbprint, so derive it locally if needed.)
MS_CERT_THUMBPRINT=

# RVO OAuth Credentials (Optional: Leave empty to disable RVO Integration)
# Required: No
RVO_CLIENT_ID=
RVO_CLIENT_NAME=
RVO_PKIO_PRIVATE_KEY=
# Must point to the dedicated callback route, e.g. https://yourdomain.com/callback/rvo
RVO_REDIRECT_URI=

# -------------------------------------
# Map & Data Configuration
# -------------------------------------
# Map provider to use for displaying maps.
# Options: "maptiler" | "osm"
# Required: Yes
PUBLIC_MAP_PROVIDER=osm

# MapTiler API key for displaying maps if PUBLIC_MAP_PROVIDER is set to "maptiler".
# Required: Yes (if PUBLIC_MAP_PROVIDER is "maptiler")
PUBLIC_MAPTILER_API_KEY=

# Google Gemini API key for AI-driven planning (Gerrit).
# Required: Only if the Gerrit agent / AI-driven fertilizer planning feature is
# enabled. Deployments that do not use Gerrit or any agent-based features can
# leave this blank.
GEMINI_API_KEY=

# NMI API key for accessing NMI services.
# Used for: soil parameter estimates (atlas), soil analysis PDF extraction,
# nutrient advice, mineralization, calculator, AI-driven planning (Gerrit),
# and syncing the BLN3 measures catalogue on startup.
# Required: No (but many features are disabled without it)
NMI_API_KEY=

# -------------------------------------
# Analytics & Error Tracking (Optional)
# -------------------------------------
# To enable Sentry error tracking and performance monitoring, fill in ALL PUBLIC_SENTRY_* variables below.
# Leave them empty to disable Sentry integration.
# Required: No
PUBLIC_SENTRY_ORG=
PUBLIC_SENTRY_PROJECT=
PUBLIC_SENTRY_DSN=
PUBLIC_SENTRY_TRACE_SAMPLE_RATE=1.0 # Sample rate for performance monitoring (0.0 to 1.0)
PUBLIC_SENTRY_REPLAY_SAMPLE_RATE=0.1 # Sample rate for session replay (0.0 to 1.0)
PUBLIC_SENTRY_REPLAY_SAMPLE_RATE_ON_ERROR=1.0 # Sample rate for session replay when errors occur (0.0 to 1.0)
PUBLIC_SENTRY_PROFILE_SAMPLE_RATE=1.0 # Sample rate for profiling (0.0 to 1.0)
PUBLIC_SENTRY_SECURITY_REPORT_URI= # Used for CSP reporting

# Sentry Auth Token (Required ONLY for uploading source maps during build, not for runtime)
# Required: No (for runtime)
SENTRY_AUTH_TOKEN=

# To enable PostHog product analytics, fill in BOTH variables below.
# Leave them empty to disable PostHog integration.
# Required: No
PUBLIC_POSTHOG_KEY= # Example: phc_...
PUBLIC_POSTHOG_HOST= # Example: https://eu.i.posthog.com


# -------------------------------------
# Mail Configuration (Optional)
# -------------------------------------
# To enable sending emails to users, fill in ALL variables below. Currently only postmark is supported as Email API provider
# Leave them empty to disable email sending.
# Required: No
POSTMARK_API_KEY=
POSTMARK_SENDER_ADDRESS=
POSTMARK_SENDER_NAME=

# -------------------------------------
# LangSmith Tracing (optional, development)
# -------------------------------------
# Enable LangSmith tracing for full observability of agent reasoning,
# tool calls, token usage, and latency. No code changes required —
# set these env vars and all LangGraph runs are automatically traced.
# Obtain an API key at https://smith.langchain.com/
# Required: No (omit or leave empty to disable)
LANGSMITH_TRACING=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# -------------------------------------
# Google Cloud Storage
# -------------------------------------
# GCS bucket name. Used for visual soil analysis photos and other user files.
# Required: Yes (if any GCS-backed feature is enabled)
GCS_BUCKET_NAME=

# Authentication — choose ONE of the following methods (in order of preference):
#
# 1. Application Default Credentials (ADC) — recommended.
#    • On GCP (Cloud Run / GKE / GCE / App Engine): attach a service account to
#      the runtime. No env vars required beyond GCS_BUCKET_NAME.
#    • Locally: run `gcloud auth application-default login`.
#    • Any environment: set GOOGLE_APPLICATION_CREDENTIALS to the path of a
#      Workload Identity Federation configuration file (avoids long-lived keys).
#
# 2. Workload Identity Federation (non-GCP deployments, e.g. Vercel / Railway).
#    Set GOOGLE_APPLICATION_CREDENTIALS to the path of the WIF config file AND
#    set GCS_SERVICE_ACCOUNT_EMAIL so the library knows which SA to sign as.
#    Docs: https://cloud.google.com/iam/docs/workload-identity-federation
#
GOOGLE_APPLICATION_CREDENTIALS=
GCS_SERVICE_ACCOUNT_EMAIL=

# 3. Inline service account key — NOT recommended (long-lived credential).
#    Only use when ADC and WIF are not available.
#    Base64-encode a JSON key file: base64 -w 0 service-account-key.json
#    The service account needs roles/storage.objectAdmin on GCS_BUCKET_NAME
#    and roles/iam.serviceAccountTokenCreator on itself for signed URLs.
#
GCS_SERVICE_ACCOUNT_KEY=