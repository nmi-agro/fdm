# syntax=docker/dockerfile:1.7
ARG NODE_VERSION=24
ARG PROJECT=@nmi-agro/fdm-app

# Base stage
FROM node:${NODE_VERSION}-alpine AS base
RUN apk update && apk add --no-cache libc6-compat git
RUN npm install -g pnpm turbo
WORKDIR /app

# Pruner stage
FROM base AS pruner
COPY . .
RUN turbo prune --scope=@nmi-agro/fdm-app --docker

# Builder stage
FROM base AS builder
WORKDIR /app

# Copy lockfile and package.json's of isolated subworkspace
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

# Install dependencies.
# --config.prefer-online=true forces pnpm to re-fetch package metadata from the
# registry on every build, ensuring the "time" field is present in the store cache.
# This is needed because minimumReleaseAge requires the "time" field, and a stale
# Docker cache may contain metadata fetched before that field was recorded.
# Tarballs are still served from the cache (content-addressable), so build speed
# is largely unaffected.
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --config.prefer-online=true

# Copy source code of isolated subworkspace
COPY --from=pruner /app/out/full/ .

# Ensure root tsconfig files are present (turbo prune might miss them if not explicitly referenced as workspace deps)
COPY --from=pruner /app/tsconfig*.json ./

# Build the project
RUN pnpm build

# Create a self-contained production deployment bundle.
# --legacy is required because inject-workspace-packages=true is not set; without
# it pnpm v10+ refuses to deploy. The minimumReleaseAge / missing "time" field
# issue on the deploy step is avoided by --config.prefer-online=true on the
# install step above (metadata is refreshed and stored before deploy runs).
RUN --mount=type=cache,target=/root/.local/share/pnpm/store \
    pnpm --filter=@nmi-agro/fdm-app deploy --prod --legacy --config.resolution-mode=highest --config.prefer-online=true /app/deployed

# Production runner stage
FROM node:${NODE_VERSION}-alpine AS runner
WORKDIR /app

# Add non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 user && \
    apk add --no-cache libc6-compat curl

# Copy production node_modules from the deploy bundle.
# This avoids re-fetching and re-building git-hosted packages (like
# @geomatico/maplibre-cog-protocol) which fail when tsc is unavailable in --prod mode.
COPY --from=builder --chown=user:nodejs /app/deployed/node_modules ./fdm-app/node_modules
COPY --from=builder --chown=user:nodejs /app/deployed/package.json ./fdm-app/package.json

# Copy built artifacts
# App build
COPY --from=builder --chown=user:nodejs /app/fdm-app/build ./fdm-app/build
COPY --from=builder --chown=user:nodejs /app/fdm-app/app ./fdm-app/app
COPY --from=builder --chown=user:nodejs /app/fdm-app/public ./fdm-app/public
COPY --from=builder --chown=user:nodejs /app/fdm-app/instrument.server.mjs ./fdm-app/instrument.server.mjs

# Create uploads directory with correct ownership before switching to non-root user
RUN mkdir -p /app/fdm-app/uploads/shapefiles && \
    chown -R user:nodejs /app/fdm-app/uploads

# Set production environment
ENV NODE_ENV=production
ENV PORT=8080

# Use non-root user
USER user

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s \
  CMD curl -f http://localhost:8080/health || exit 1

WORKDIR /app/fdm-app
# Run node directly instead of via `pnpm start` to bypass pnpm v11's pre-script
# dependency status check, which compares node_modules/.modules.yaml (written by
# the builder running as root) against the runner's store path (non-root user) and
# tries to purge + reinstall — failing because the runner has no pnpm store.
CMD ["/bin/sh", "-c", "node ./app/lib/fdm-migrate.server.js && export NODE_OPTIONS='--import ./instrument.server.mjs' && exec ./node_modules/.bin/react-router-serve ./build/server/index.js"]
