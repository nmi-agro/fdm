ARG NODE_VERSION=24
ARG PROJECT=@nmi-agro/fdm-app

# Base stage
FROM node:${NODE_VERSION}-alpine AS base
ENV CI=true
RUN apk update && apk add --no-cache libc6-compat
RUN npm install -g pnpm turbo
WORKDIR /app

# Pruner stage
FROM base AS pruner
COPY . .
RUN turbo prune --scope=@nmi-agro/fdm-app --docker

# Builder stage
FROM base AS builder
WORKDIR /app

# Copy lockfile and package.json's of isolated subworkspace
COPY --from=pruner /app/out/json/ .
COPY --from=pruner /app/out/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=pruner /app/out/pnpm-workspace.yaml ./pnpm-workspace.yaml

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy source code of isolated subworkspace
COPY --from=pruner /app/out/full/ .

# Ensure root tsconfig files are present (turbo prune might miss them if not explicitly referenced as workspace deps)
COPY --from=pruner /app/tsconfig*.json ./

# Build the project
RUN pnpm build && pnpm prune --prod

# Production runner stage
FROM node:${NODE_VERSION}-alpine AS runner
ENV CI=true
WORKDIR /app

# Add non-root user for security
RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 user && \
    apk add --no-cache libc6-compat curl && \
    npm install -g pnpm

# Copy production node_modules and workspace packages from builder
COPY --from=builder --chown=user:nodejs /app/node_modules ./node_modules
COPY --from=builder --chown=user:nodejs /app/fdm-app/node_modules ./fdm-app/node_modules
COPY --from=builder --chown=user:nodejs /app/pnpm-workspace.yaml /app/package.json ./
COPY --from=builder --chown=user:nodejs /app/fdm-core ./fdm-core
COPY --from=builder --chown=user:nodejs /app/fdm-data ./fdm-data
COPY --from=builder --chown=user:nodejs /app/fdm-calculator ./fdm-calculator
COPY --from=builder --chown=user:nodejs /app/fdm-agents ./fdm-agents
COPY --from=builder --chown=user:nodejs /app/fdm-rvo ./fdm-rvo

# Copy app artifacts
COPY --from=builder --chown=user:nodejs /app/fdm-app/build ./fdm-app/build
COPY --from=builder --chown=user:nodejs /app/fdm-app/app ./fdm-app/app
COPY --from=builder --chown=user:nodejs /app/fdm-app/public ./fdm-app/public
COPY --from=builder --chown=user:nodejs /app/fdm-app/instrument.server.mjs ./fdm-app/instrument.server.mjs
COPY --from=builder --chown=user:nodejs /app/fdm-app/package.json ./fdm-app/package.json

# Set production environment
ENV NODE_ENV=production
ENV PORT=8080

# Use non-root user
USER user

# Expose port
EXPOSE 8080

# Health check
HEALTHCHECK --interval=30s --timeout=3s \
  CMD curl -f http://localhost:8080/health || exit 1

WORKDIR /app/fdm-app
CMD ["pnpm", "start"]
