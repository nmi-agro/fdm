{
    "extends": "../tsconfig.apps.json",
    "include": [
        "**/*.ts",
        "**/*.tsx",
        "**/.server/**/*.ts",
        "**/.server/**/*.tsx",
        "**/.client/**/*.ts",
        "**/.client/**/*.tsx",
        ".react-router/types/**/*",
        "app/routes/*.tsx",
        "app/components/**/*.tsx",
        "app/lib/fdm-migrate.server.js",
        "app/types/public-env.d.ts"
    ],
    "compilerOptions": {
        "types": ["@react-router/node", "vite/client"],
        "paths": {
            "@/*": ["./*"],
            "~/*": ["./app/*"],
            "@nmi-agro/fdm-core": ["../fdm-core/src/index.ts"],
            "@nmi-agro/fdm-data": ["../fdm-data/src/index.ts"],
            "@nmi-agro/fdm-calculator": ["../fdm-calculator/src/index.ts"]
        },
        "rootDirs": [".", "./.react-router/types"]
    }
}
