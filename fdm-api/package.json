{
    "name": "@nmi-agro/fdm-api",
    "private": true,
    "version": "0.1.0",
    "description": "Hono-based REST API for the Farm Data Model",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "bin": {
        "fdm-api": "./dist/server.js"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsdown",
        "dev": "tsx watch src/server.ts",
        "start": "node dist/server.js",
        "document": "typedoc src/index.ts --plugin typedoc-plugin-missing-exports --skipErrorChecking",
        "check-types": "tsc --noEmit",
        "preinstall": "npx only-allow pnpm",
        "test": "vitest run",
        "test-coverage": "vitest run --coverage",
        "watch": "vitest"
    },
    "dependencies": {
        "@hono/node-server": "^1.14.4",
        "@hono/zod-openapi": "^1.3.0",
        "@nmi-agro/fdm-core": "workspace:*",
        "@scalar/hono-api-reference": "^0.5.173",
        "drizzle-orm": "catalog:",
        "hono": "^4.7.11",
        "nanoid": "^5.1.9",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "@vitest/coverage-v8": "catalog:",
        "tsdown": "catalog:",
        "tsx": "^4.19.4",
        "typedoc": "catalog:",
        "typedoc-plugin-missing-exports": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "engines": {
        "node": ">=24.0.0"
    }
}
