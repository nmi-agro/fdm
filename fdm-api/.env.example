# -------------------------------------
# General Configuration
# -------------------------------------
# Port the API server will listen on.
# Required: Yes (Defaults to 6173 for local dev, 8080 in production)
PORT=6173

# Public name of the application exposed in the OpenAPI document.
# Required: Yes
PUBLIC_FDM_NAME=FDM

# Canonical base URL of the API service (used for problem type links in error responses).
# Example: https://api.yourdomain.com
# Required: Yes
PUBLIC_FDM_URL=

# Comma-separated list of origins that are allowed to call this API (CORS).
# Leave empty to allow all origins (*). Restrict in production to your own domains.
# Example: https://app.yourdomain.com,https://staging.yourdomain.com
# Required: No (defaults to * — open to all origins)
FDM_API_ALLOWED_ORIGINS=

# -------------------------------------
# Database Configuration (PostgreSQL)
# -------------------------------------
# Required: Yes
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# -------------------------------------
# Authentication (Better Auth)
# -------------------------------------
# Secret key used by the better-auth library for token signing.
# Generate with: openssl rand -base64 32
# Required: Yes
# ⚠️  MUST be identical to BETTER_AUTH_SECRET in fdm-app — fdm-api validates
#     API keys that were issued by fdm-app's Better Auth instance, so both
#     services must share the same secret to verify tokens correctly.
BETTER_AUTH_SECRET=

# Full base URL of this API service (used for Better Auth cookie domain / redirects).
# Example: https://api.yourdomain.com
# Required: Yes
BETTER_AUTH_URL=

# -------------------------------------
# Sentry (Optional)
# -------------------------------------
# Sentry DSN for error tracking and performance monitoring.
# Required: No (error reporting is disabled when not set)
PUBLIC_SENTRY_DSN=

# Sentry release identifier (used to correlate errors to a specific deployment).
# If not set, falls back to npm_package_version.
# Required: No
SENTRY_RELEASE=

# Fraction of transactions to record for performance tracing (0.0–1.0).
# Required: No (defaults to 0.1 — 10%)
PUBLIC_SENTRY_TRACE_SAMPLE_RATE=0.1

# Fraction of trace sessions to profile (0.0–1.0).
# Required: No (defaults to 0 — profiling disabled)
PUBLIC_SENTRY_PROFILE_SAMPLE_RATE=0

# -------------------------------------
# NMI Services (Optional)
# -------------------------------------
# NMI API key for nutrient advice, soil estimates, and calculator features.
# Required: No (calculation endpoints will be unavailable without it)
NMI_API_KEY=
