{
    "name": "@nmi-agro/fdm-core",
    "private": false,
    "version": "0.31.2",
    "description": "Interface for the Farm Data Model",
    "license": "MIT",
    "homepage": "https://svenvw.github.io/fdm/",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nmi-agro/fdm.git"
    },
    "bugs": "https://github.com/nmi-agro/fdm/issues/new",
    "author": {
        "name": "Sven Verweij",
        "email": "37927107+SvenVw@users.noreply.github.com",
        "url": "https://github.com/SvenVw"
    },
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "coverage": "dotenvx run -- vitest run --coverage",
        "db:generate-authn": "pnpm dlx auth generate --config ./src/db/generator/authn.ts --output ./src/db/schema-authn.ts --y",
        "db:generate": "npx drizzle-kit generate",
        "document": "npx typedoc src --plugin typedoc-plugin-missing-exports",
        "dotenvx": "dotenvx",
        "build": "dotenvx run -- tsdown",
        "check-types": "tsc --noEmit",
        "preinstall": "npx only-allow pnpm",
        "preview": "vite preview",
        "test": "dotenvx run -- vitest run",
        "test-coverage": "dotenvx run -- vitest run --coverage",
        "watch": "dotenvx run -- vitest"
    },
    "devDependencies": {
        "@dotenvx/dotenvx": "catalog:",
        "@nmi-agro/fdm-data": "workspace:^0.19.3",
        "@types/node": "catalog:",
        "@types/validator": "^13.15.10",
        "@vitest/coverage-v8": "catalog:",
        "drizzle-kit": "catalog:",
        "fs-extra": "^11.3.4",
        "globals": "^17.4.0",
        "tsdown": "catalog:",
        "typedoc": "catalog:",
        "typedoc-plugin-missing-exports": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "dependencies": {
        "@nmi-agro/fdm-data": "workspace:*",
        "@types/geojson": "^7946.0.16",
        "better-auth": "catalog:",
        "decimal.js": "^10.6.0",
        "drizzle-orm": "catalog:",
        "nanoid": "^5.1.7",
        "postgres": "^3.4.9",
        "safe-stable-stringify": "^2.5.0",
        "unique-username-generator": "^1.5.1",
        "validator": "^13.15.35",
        "zod": "^4.3.6"
    },
    "packageManager": "pnpm@10.33.0",
    "engines": {
        "node": ">=24.0.0"
    },
    "publishConfig": {
        "registry": "https://npm.pkg.github.com"
    }
}
